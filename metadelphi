#!/usr/bin/env bash
# Global Metadelphi CLI wrapper.
# This script is symlinked or copied onto the user's PATH by install.sh.

set -e

# Resolve the project directory from this script's real location.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

PYTHON_BIN="$PROJECT_DIR/.venv/bin/python"
SERVICE_RUNNER="$PROJECT_DIR/service_runner.py"

if [ ! -x "$PYTHON_BIN" ]; then
    echo "Error: Metadelphi virtual environment not found at $PROJECT_DIR/.venv"
    echo "Please run the installer first."
    exit 1
fi

if [ ! -f "$SERVICE_RUNNER" ]; then
    echo "Error: Metadelphi service runner not found at $SERVICE_RUNNER"
    exit 1
fi

# Handle help without invoking the service runner.
if [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    cat <<EOF
Metadelphi CLI

Usage: metadelphi [command] [options]

Commands:
  (no command)        Start the background service and open the browser
  start               Start the background service and open the browser
  start --no-browser  Start without opening the browser
  start --port 9000   Start on a custom port (-p 9000 also works)
  stop                Stop the background service
  restart             Restart the background service
  restart --port 9000 Restart on a custom port
  status              Check whether the service is running
  logs                Show the backend log
  logs -f             Follow the backend log
  config              Open the web UI in your browser
  config --print-url  Print the web UI URL without opening the browser
  update              Update Metadelphi to the latest release
  update --version    Update to a specific release version
  uninstall           Remove Metadelphi from this machine (backs up data)
  uninstall --remove-data  Remove Metadelphi and delete all data
  help                Show this help message

Examples:
  metadelphi
  metadelphi start --port 9000
  metadelphi restart -p 9000 --no-browser
  metadelphi update
EOF
    exit 0
fi

# Default to 'start' when no command is provided, or when the first argument
# looks like an option (e.g., `metadelphi --no-browser`).
if [ $# -eq 0 ] || [[ "$1" == -* ]]; then
    set -- start "$@"
fi

exec "$PYTHON_BIN" "$SERVICE_RUNNER" "$@"
