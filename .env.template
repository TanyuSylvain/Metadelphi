# Metadelphi API Configuration Template
# Copy this file to .env and add your API keys
# At least one API key is required for the application to work

# Mistral AI
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Qwen (Alibaba DashScope)
# Get your API key from: https://dashscope.aliyuncs.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# GLM (Zhipu AI)
# Get your API key from: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MiniMax
# Get your API key from: https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.com/v1

# DeepSeek
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI-compatible API
# Can be OpenAI or any OpenAI-compatible service
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ============================================================
# MCP Server Configuration (Optional)
# ============================================================
# MCP servers provide extended tool capabilities like web search.

# Option 1: Use DASHSCOPE_API_KEY for default Bailian MCP servers (recommended)
# Get your API key from: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Option 2: Advanced - JSON configuration for custom MCP servers
# Uncomment and edit to configure multiple custom MCP servers
# MCP_SERVERS=[{"name":"web-search","url":"https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse","transport":"sse","api_key_env":"DASHSCOPE_API_KEY"},{"name":"web-parser","url":"https://dashscope.aliyuncs.com/api/v1/mcps/WebParser/sse","transport":"sse","api_key_env":"DASHSCOPE_API_KEY"}]

# Legacy MCP configuration (for backward compatibility)
# WEB_SEARCH_MCP_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse
# WEB_PARSER_MCP_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebParser/sse
# MCP_TRANSPORT_TYPE=sse

# ============================================================
# Tool Execution Configuration
# ============================================================
# Maximum number of tools to execute in parallel (default: 5)
# Increase for faster execution when multiple tools are called simultaneously
MAX_TOOL_CONCURRENCY=5
